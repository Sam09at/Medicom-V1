# ── Supabase (browser-safe keys only) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh...

# ── Monitoring ──
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=

# ── Environment ──
VITE_ENV=development

# ─────────────────────────────────────────────────────────────
# SERVER-SIDE SECRETS — NEVER prefix these with VITE_
# Store them ONLY in Supabase Edge Function environment variables
# (Dashboard → Edge Functions → Manage secrets)
# ─────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=eyJh...   ← bypasses all RLS, Edge Functions only
# GEMINI_API_KEY=                     ← billed AI calls
# TWILIO_ACCOUNT_SID=                 ← SMS sending
# TWILIO_AUTH_TOKEN=                  ← Twilio master credential
# RESEND_API_KEY=                     ← transactional email
